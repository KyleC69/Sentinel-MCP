#: includes/abilities-stats.php
msgid "Site stats and counts"
msgstr "Estadísticas y conteos del sitio"

#: includes/abilities-stats.php
msgid "Lightweight counts: posts per CPT and status, comments, users per role, media usage."
msgstr "Conteos ligeros: posts por CPT y estado, comentarios, usuarios por rol y uso de medios."

#: includes/abilities-fse-read.php
msgid "Full Site Editing (read-only)"
msgstr "Full Site Editing (solo lectura)"

#: includes/abilities-fse-read.php
msgid "Read-only inspection of block patterns and FSE templates. Editing is Premium."
msgstr "Inspección de solo lectura de patrones de bloque y plantillas FSE. La edición es Premium."

#: includes/abilities-menus-widgets-read.php
msgid "Menus, widgets and sidebars (read-only)"
msgstr "Menús, widgets y barras laterales (solo lectura)"

#: includes/abilities-menus-widgets-read.php
msgid "Read-only access to classic navigation menus, widget instances and registered sidebars."
msgstr "Acceso de solo lectura a los menús clásicos, instancias de widgets y barras laterales registradas."

#: includes/abilities-wc-read.php
msgid "WooCommerce (read-only)"
msgstr "WooCommerce (solo lectura)"

#: includes/abilities-wc-read.php
msgid "Read-only access to WooCommerce store info, products, recent orders and coupons. Editing WooCommerce data is Premium."
msgstr "Acceso de solo lectura a la información de la tienda WooCommerce, productos, pedidos recientes y cupones. La edición de datos de WooCommerce es Premium."

#: includes/abilities-seo-read.php
msgid "SEO (read-only)"
msgstr "SEO (solo lectura)"

#: includes/abilities-seo-read.php
msgid "Read SEO meta from any active SEO plugin (Yoast, Rank Math, AIOSEO, The SEO Framework, SureRank, SEOPress, Slim SEO, Squirrly). Bulk write SEO is Premium."
msgstr "Lee la meta SEO de cualquier plugin SEO activo (Yoast, Rank Math, AIOSEO, The SEO Framework, SureRank, SEOPress, Slim SEO, Squirrly). La escritura masiva de SEO es Premium."

#: includes/abilities-i18n-read.php
msgid "Multilingual (read-only)"
msgstr "Multilingüe (solo lectura)"

#: includes/abilities-i18n-read.php
msgid "Read languages, post translations and string translations from Polylang, WPML or TranslatePress. Writing translations is Premium."
msgstr "Lee idiomas, traducciones de posts y traducciones de cadenas de Polylang, WPML o TranslatePress. La escritura de traducciones es Premium."

#: includes/oauth/class-mcp-oauth-permissions.php
msgid "This OAuth client is not authorized to call ability \"%s\"."
msgstr "Este cliente OAuth no está autorizado para invocar la habilidad \"%s\"."

#: includes/oauth/class-mcp-oauth-permissions.php
msgid "Rate limit exceeded."
msgstr "Límite de peticiones excedido."

#: mcp-sentinel.php
msgid "Sentinel-MCP requires PHP %1$s or higher. Your server is running PHP %2$s. Please upgrade PHP and try again."
msgstr "Sentinel-MCP requiere PHP %1$s o superior. Tu servidor usa PHP %2$s. Actualiza PHP y vuelve a intentarlo."

#: mcp-sentinel.php
msgid "Plugin activation error"
msgstr "Error de activación del plugin"

#: mcp-sentinel.php
msgid "The Premium version is active. You can safely deactivate the Lite version."
msgstr "La versión Premium está activa. Puedes desactivar la versión Lite con seguridad."

# Admin tabs.
msgid "Get Started"
msgstr "Primeros pasos"

msgid "Status"
msgstr "Estado"

msgid "Connect"
msgstr "Conectar"

msgid "Prompts"
msgstr "Prompts"

msgid "Settings"
msgstr "Ajustes"

msgid "Authentication"
msgstr "Autenticación"

msgid "Activity Log"
msgstr "Registro de actividad"

msgid "Info"
msgstr "Información"

msgid "Go Premium"
msgstr "Pasar a Premium"

# Get Started tab.
msgid "Step 1 — Environment check"
msgstr "Paso 1 — Comprobación del entorno"

msgid "Step 2 — Create an OAuth client"
msgstr "Paso 2 — Crea un cliente OAuth"

msgid "Step 3 — Pick your AI client"
msgstr "Paso 3 — Elige tu cliente de IA"

msgid "Step 4 — Test the connection"
msgstr "Paso 4 — Prueba la conexión"

msgid "Open Authentication tab"
msgstr "Abrir pestaña de autenticación"

msgid "Open Connect tab"
msgstr "Abrir pestaña de conexión"

# Connect tab.
msgid "Connect your AI assistant"
msgstr "Conecta tu asistente de IA"

# Prompts tab.
msgid "Prompts gallery (%s)"
msgstr "Galería de prompts (%s)"

msgid "Copy any of these prompts and paste them into your AI client (Claude Desktop, Cursor, ChatGPT…) connected to this site."
msgstr "Copia cualquiera de estos prompts y pégalo en tu cliente de IA (Claude Desktop, Cursor, ChatGPT…) conectado a este sitio."

msgid "All categories"
msgstr "Todas las categorías"

msgid "Search…"
msgstr "Buscar…"

msgid "Filter"
msgstr "Filtrar"

msgid "No prompts match the current filters."
msgstr "Ningún prompt coincide con los filtros actuales."

# OAuth permissions.
msgid "Permissions"
msgstr "Permisos"

msgid "OAuth client not found."
msgstr "No se ha encontrado el cliente OAuth."

msgid "Back to OAuth clients"
msgstr "Volver a los clientes OAuth"

msgid "Permissions for %s"
msgstr "Permisos para %s"

msgid "Restrict which abilities this OAuth client can call. By default a client may call every ability the WordPress user has capability for. Restricting here adds an extra allowlist on top of WordPress capabilities."
msgstr "Restringe qué abilities puede invocar este cliente OAuth. Por defecto, un cliente puede invocar cualquier ability para la que el usuario de WordPress tenga capability. Restringir aquí añade una lista de permitidos adicional sobre las capabilities de WordPress."

msgid "All abilities"
msgstr "Todas las abilities"

msgid "No allowlist (default)."
msgstr "Sin lista de permitidos (por defecto)."

msgid "Restricted to selected abilities"
msgstr "Restringido a las abilities seleccionadas"

msgid "Save permissions"
msgstr "Guardar permisos"

msgid "Cancel"
msgstr "Cancelar"

msgid "Core"
msgstr "Núcleo"

# Premium tab.
msgid "Unlock the Full Power of MCP Content Manager"
msgstr "Desbloquea todo el potencial de MCP Content Manager"

msgid "Premium ships %1$s+ abilities across %2$s categories. Manage your entire WordPress site — content, store, security and more — from Claude, ChatGPT, Copilot or any MCP client."
msgstr "Premium incluye más de %1$s abilities en %2$s categorías. Gestiona tu sitio WordPress completo (contenido, tienda, seguridad y más) desde Claude, ChatGPT, Copilot o cualquier cliente MCP."

msgid "Search features…"
msgstr "Buscar características…"

msgid "Clear"
msgstr "Limpiar"

msgid "No features match the current filters."
msgstr "Ninguna característica coincide con los filtros actuales."

msgid "Example prompt"
msgstr "Prompt de ejemplo"

msgid "Learn more"
msgstr "Saber más"

msgid "Get MCP Content Manager Premium"
msgstr "Obtener MCP Content Manager Premium"

# Detected integrations.
msgid "Detected on this site"
msgstr "Detectado en este sitio"

msgid "WooCommerce detected"
msgstr "WooCommerce detectado"

msgid "Premium adds 8 modules with 60+ abilities for products, orders, customers, coupons, shipping, taxes and subscriptions."
msgstr "Premium añade 8 módulos con más de 60 abilities para productos, pedidos, clientes, cupones, envíos, impuestos y suscripciones."

msgid "Yoast SEO detected"
msgstr "Yoast SEO detectado"

msgid "Premium adds full write SEO management across Yoast, Rank Math and AIOSEO."
msgstr "Premium añade escritura completa de SEO en Yoast, Rank Math y AIOSEO."

msgid "Rank Math detected"
msgstr "Rank Math detectado"

msgid "Premium adds full write SEO management for Rank Math."
msgstr "Premium añade escritura completa de SEO para Rank Math."

msgid "Multilingual plugin detected"
msgstr "Plugin multilingüe detectado"

msgid "Premium adds translation creation and per-language sync for Polylang, WPML and TranslatePress."
msgstr "Premium añade creación de traducciones y sincronización por idioma para Polylang, WPML y TranslatePress."

msgid "ACF detected"
msgstr "ACF detectado"

msgid "Premium adds universal field write across all ACF field types."
msgstr "Premium añade escritura universal de campos en todos los tipos ACF."

msgid "See Premium features"
msgstr "Ver características de Premium"

msgid "Need more power?"
msgstr "¿Necesitas más potencia?"

msgid "MCP Content Manager Premium"
msgstr "MCP Content Manager Premium"

# Settings tab.
msgid "Debug Logging"
msgstr "Registro de depuración"

msgid "When enabled, MCP Content Manager writes debug messages to the PHP error log. Useful for troubleshooting, but should be disabled in production to avoid excessive log growth."
msgstr "Cuando está activo, MCP Content Manager escribe mensajes de depuración en el log de PHP. Es útil para diagnosticar problemas, pero debe estar desactivado en producción para evitar que el log crezca en exceso."

msgid "Enable debug logging"
msgstr "Activar registro de depuración"

msgid "Write [SENTINEL-DEBUG] messages to the PHP error log."
msgstr "Escribir mensajes [SENTINEL-DEBUG] en el log de PHP."

msgid "AI Image Generation (Gemini)"
msgstr "Generación de imágenes con IA (Gemini)"

msgid "Configure a Google Gemini API key to enable the generate-image and set-featured-from-prompt abilities. Lite uses the Gemini generateContent endpoint with image output. Imagen API, multiple aspect ratios, 2K/4K, image editing and safety controls are reserved for Premium."
msgstr "Configura una API key de Google Gemini para activar las abilities generate-image y set-featured-from-prompt. La versión Lite usa el endpoint generateContent de Gemini con salida de imagen. Imagen API, múltiples relaciones de aspecto, 2K/4K, edición de imágenes y controles de seguridad se reservan para Premium."

msgid "Get a free API key at %s."
msgstr "Consigue una API key gratuita en %s."

msgid "Gemini API key"
msgstr "API key de Gemini"

msgid "Currently configured:"
msgstr "Configurada actualmente:"

msgid "Paste your API key"
msgstr "Pega tu API key"

msgid "Leave blank to keep current key"
msgstr "Déjalo en blanco para mantener la API key actual"

msgid "Remove key"
msgstr "Eliminar API key"

msgid "Model"
msgstr "Modelo"

msgid "Default: %s. Must be a Gemini model that supports image output."
msgstr "Por defecto: %s. Debe ser un modelo Gemini que soporte salida de imagen."

msgid "Save Settings"
msgstr "Guardar ajustes"

# AI Image abilities category.
msgid "AI Image Generation"
msgstr "Generación de imágenes con IA"

msgid "Generate images via Google Gemini and save them to the Media Library. Multiple aspect ratios, sizes and image editing are Premium."
msgstr "Genera imágenes con Google Gemini y guárdalas en la biblioteca de medios. Múltiples relaciones de aspecto, tamaños y edición de imágenes son Premium."

# Activity Log tab pieces.
msgid "Last 30 days of MCP tool calls. Retention is fixed at 30 days; older entries are purged daily."
msgstr "Últimos 30 días de llamadas MCP. La retención es fija en 30 días; las entradas antiguas se purgan a diario."
