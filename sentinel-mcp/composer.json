{
    "name": "kylec69/sentinel-mcp",
    "description": "Sentinel-MCP WordPress plugin — MCP server exposing 40+ abilities for content management, media, users, system info, WooCommerce, SEO, i18n, and more.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "readme": "readme.txt",
    "source": {
        "reference": "",
        "type": "git",
        "url": "https://github.com/kylec69/sentinel-mcp"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/KyleC69"
        }
    ],
    "authors": [
        {
            "name": "Kyle L Crowder",
            "email": "kcrowdergoog@gmail.com",
            "homepage": "https://kylec69.github.io/Sentinel-MCP",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.8",
        "ramsey/uuid": "^4.7",
        "soukicz/llm": "^0.1",
        "swaggest/json-schema": "^0.12",
        "symfony/polyfill-php83": "^1.28",
        "wordpress/mcp-adapter": "^0.5.0"
    },
    "autoload": {
        "psr-4": {
            "SentinelMCP\\": "includes/"
        },
        "classmap": [
            "includes/",
            "includes/admin/",
            "includes/chat/",
            "includes/oauth/",
            "includes/i18n/",
            "includes/seo/",
            "includes/Collectors/",
            "includes/Logging/"
        ]
    },
    "config": {
        "vendor-dir": "vendor",
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
